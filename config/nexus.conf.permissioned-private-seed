#
# This is an example seed-node configuration for a private blockchain. If there
# is more than one seed node used, only one must use the generate statement.
#       
#default RPC user/pass.  PLEASE CHANGE THESE TO SUITABLE VALUES
#WARNING: rpcremote enables remote RPC access. Keep RPC bound to localhost or a
#strictly controlled private-network interface and keep rpcallowip limited to
#trusted hosts only. Do not enable remote RPC on internet-facing nodes without
#strong authentication and network access controls.
rpcuser=username
rpcpassword=password
rpcremote=1

#default API user/pass to blank for private network and disable authentication of API requests
#WARNING: apiremote enables remote API access and apiauth=0 disables API
# WARNING: Do not enable remote RPC by default in sample configs.
# Only enable this together with strict rpcallowip and bind-address settings.
# Never expose RPC on an internet-facing node without strong access controls.
#rpcremote=1

#default API user/pass to blank for private network and disable authentication of API requests
apiauth=0
apiuser=
apipassword=
# WARNING: Do not enable remote API by default in sample configs.
# Only enable this together with strict API allowlisting and bind-address settings.
# Never expose the API on an internet-facing node without strong access controls.
#apiremote=1

rpcallowip=127.0.0.1
testnet=100
beta=0
fastsync=1
server=1
daemon=1
threads=10            
verbose=3    
maxconnections=16
private=1
apisessions=1
pmanager=1
generate=one-seed
argon2_memory=4
nodns=1    
argon2=1
    