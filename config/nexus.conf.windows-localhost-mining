#
# Example Windows localhost node configuration for running nexus.exe with
# NexusMiner.exe on the same machine.
#
# Copy this file to:
#   %APPDATA%\Nexus\nexus.conf
#

# Keep the Windows portable release in the foreground by default.
daemon=0

# RPC/API credentials. This file is packaged as nexus.conf.example and is not
# loaded by nexus.exe unless you copy it to the Windows config directory.
# Replace these placeholders before first use.
# Do not expose this node to any network until these placeholders are changed.
rpcuser=YOUR_RPC_USER_HERE
rpcpassword=YOUR_RPC_PASSWORD_HERE
apiuser=YOUR_API_USER_HERE
apipassword=YOUR_API_PASSWORD_HERE

# Enable node services.
server=1
listen=1
maxconnections=16

# Enable both localhost mining lanes used by NexusMiner.
mining=1
miningport=9323
legacyminingport=8323
llpallowip=127.0.0.1

# Post-quantum miner authentication.
falcon=1

# Tune for local PRIME CPU mining tests.
miningthreads=4
miningstatelesstimeout=300
mininglegacytimeout=300

# Optional local diagnostics.
verbose=2
log=1

# For unattended mining against an existing sigchain, uncomment and fill in:
#autologin=1
#username=YOUR_SIGCHAIN_USER_HERE
#password=YOUR_SIGCHAIN_PASSWORD_HERE
#pin=YOUR_SIGCHAIN_PIN_HERE
