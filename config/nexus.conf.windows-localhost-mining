#
# Example Windows localhost node configuration for running nexus.exe with
# NexusMiner.exe on the same machine.
#
# Copy this file to:
#   %APPDATA%\Nexus\nexus.conf
#

# Keep the Windows portable release in the foreground by default.
daemon=0

###############################################################################
# REQUIRED SECURITY STEP
# This file is packaged as nexus.conf.example and is not loaded by nexus.exe
# unless you copy it to the Windows config directory.
# Do not start the node from this example, and do not expose it to any network,
# until every REPLACE_WITH_* credential placeholder below has been replaced.
###############################################################################
rpcuser=REPLACE_WITH_SECURE_RANDOM_RPC_USER
rpcpassword=REPLACE_WITH_SECURE_RANDOM_RPC_PASSWORD
apiuser=REPLACE_WITH_SECURE_RANDOM_API_USER
apipassword=REPLACE_WITH_SECURE_RANDOM_API_PASSWORD

# Enable node services.
server=1
listen=1
maxconnections=16

# Enable both localhost mining lanes used by NexusMiner.
mining=1
miningport=9323
legacyminingport=8323
llpallowip=127.0.0.1

# Post-quantum miner authentication.
falcon=1

# Tune for local PRIME CPU mining tests.
miningthreads=4
miningstatelesstimeout=300
mininglegacytimeout=300

# Optional local diagnostics.
verbose=2
log=1

# For unattended mining against an existing sigchain, uncomment and fill in:
#autologin=1
#username=ENTER_SIGCHAIN_USER_BEFORE_USE
#password=ENTER_SIGCHAIN_PASSWORD_BEFORE_USE
#pin=ENTER_SIGCHAIN_PIN_BEFORE_USE
